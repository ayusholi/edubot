    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are writing scripts for an educational podcast app. Write natural, engaging two-host conversations. Format EXACTLY with each line starting with either 'ALEX:' or 'SAM:' - no other format.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Write a podcast script about this topic for Masters in AI Technology students.\\n\\nTopic: {{ $json.topic }}\\n\\nSource content:\\n{{ $json.pdf_text.slice(0, 3000) }}\\n\\nHosts:\\n- ALEX: curious, asks great questions, represents the student perspective\\n- SAM: knowledgeable, explains clearly with analogies and real examples\\n\\nRules:\\n- Format EVERY line as: ALEX: [text] or SAM: [text]\\n- Keep total under 1500 words to fit ElevenLabs free tier\\n- Cover all key points from the content\\n- Use analogies and real-world examples\\n- End with SAM summarizing 3 key takeaways\\n- Conversational, enthusiastic tone\\n\\nStart with ALEX introducing the topic.\"\n    }\n  ],\n  \"temperature\": 0.7,\n  \"max_tokens\": 2000\n}",
        "options": {}
      },
      "id": "n5",
      "name": "Generate Podcast Script",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1264,
        304
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "ZQgh8pCPX1lVqk8F",
          "name": "OpenAI HTTP Auth"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const content = $input.first().json.choices[0].message.content;\nconst lines = content.split('\\n').filter(l => l.trim().length > 0);\n\n// ElevenLabs voice IDs (free tier voices)\nconst ALEX_VOICE = 'EXAVITQu4vr4xnSDxMaL'; // Rachel\nconst SAM_VOICE = 'pNInz6obpgDQGcFmaJgB';  // Adam\n\nconst segments = [];\nfor (const line of lines) {\n  const alexMatch = line.match(/^ALEX:\\s*(.+)/);\n  const samMatch = line.match(/^SAM:\\s*(.+)/);\n  if (alexMatch && alexMatch[1].trim()) {\n    segments.push({ text: alexMatch[1].trim(), voice_id: ALEX_VOICE, speaker: 'Alex' });\n  } else if (samMatch && samMatch[1].trim()) {\n    segments.push({ text: samMatch[1].trim(), voice_id: SAM_VOICE, speaker: 'Sam' });\n  }\n}\n\nreturn segments.map(s => ({ json: s }));"
      },
      "id": "n6",
      "name": "Parse Script into Segments",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1504,
        304
      ]
    },
    {
      "parameters": {
        "options": {}
      },
      "id": "n7",
      "name": "Process Each Segment",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        1760,
        304
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.elevenlabs.io/v1/text-to-speech/{{ $json.voice_id }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"text\": \"{{ $json.text }}\",\n  \"model_id\": \"eleven_monolingual_v1\",\n  \"voice_settings\": {\n    \"stability\": 0.5,\n    \"similarity_boost\": 0.75,\n    \"style\": 0.3,\n    \"use_speaker_boost\": true\n  }\n}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "file",
              "outputPropertyName": "audio_data"
            }
          }
        }
      },
      "id": "n8",
      "name": "Generate Audio Segment",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2000,
        304
