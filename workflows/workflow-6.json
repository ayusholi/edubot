              "type": "number"
            },
            {
              "id": "a3",
              "name": "speaker",
              "value": "={{ $('Parse Script into Segments').item.json.speaker }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "n9",
      "name": "Add Segment Index",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        2256,
        304
      ]
    },
    {
      "parameters": {
        "aggregate": "aggregateAllItemData",
        "destinationFieldName": "audio_segments",
        "options": {}
      },
      "id": "n10",
      "name": "Collect All Audio",
      "type": "n8n-nodes-base.aggregate",
      "typeVersion": 1,
      "position": [
        2512,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "// Combine all audio binary buffers into one MP3\nconst items = $input.first().json.audio_segments;\n\n// Each item has binary data from ElevenLabs\n// We collect all base64 audio data\nconst audioBuffers = items\n  .filter(item => item.audio_data)\n  .map(item => Buffer.from(item.audio_data, 'base64'));\n\nif (audioBuffers.length === 0) {\n  throw new Error('No audio segments received from ElevenLabs');\n}\n\nconst combined = Buffer.concat(audioBuffers);\nconst topic = $('Execute Workflow Trigger').item.json.topic;\nconst chatId = $('Execute Workflow Trigger').item.json.chat_id;\n\nreturn [{\n  json: {\n    chat_id: chatId,\n    topic: topic,\n    segment_count: audioBuffers.length,\n    filename: `${topic.replace(/[^a-zA-Z0-9]/g, '_')}_podcast_${new Date().toISOString().slice(0,10)}.mp3`\n  },\n  binary: {\n    podcast_audio: {\n      data: combined.toString('base64'),\n      mimeType: 'audio/mpeg',\n      fileName: `podcast_${new Date().toISOString().slice(0,10)}.mp3`\n    }\n  }\n}];"
      },
      "id": "n11",
      "name": "Combine Audio Segments",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2752,
