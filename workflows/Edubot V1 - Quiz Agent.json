    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.output || '';\n\nconst answerMatch = raw.match(/CORRECT_ANSWER:\\s*([ABCD])/i);\nconst explanationMatch = raw.match(/EXPLANATION:\\s*(.+?)(?:\\n|$)/i);\n\nconst correctAnswer = answerMatch ? answerMatch[1].toUpperCase() : 'A';\nconst explanation = explanationMatch ? explanationMatch[1].trim() : '';\n\nconst cleanQuestion = raw\n  .replace(/CORRECT_ANSWER:\\s*[ABCD].*/gi, '')\n  .replace(/EXPLANATION:.*/gi, '')\n  .trim();\n\nconst optionA = (raw.match(/^A\\.\\s*(.+)$/m) || [])[1]?.trim() || '';\nconst optionB = (raw.match(/^B\\.\\s*(.+)$/m) || [])[1]?.trim() || '';\nconst optionC = (raw.match(/^C\\.\\s*(.+)$/m) || [])[1]?.trim() || '';\nconst optionD = (raw.match(/^D\\.\\s*(.+)$/m) || [])[1]?.trim() || '';\n\nreturn [{\n  json: {\n    clean_question: cleanQuestion,\n    correct_answer: correctAnswer,\n    explanation: explanation,\n    options: JSON.stringify({ A: optionA, B: optionB, C: optionC, D: optionD }),\n    new_question_count: $('Set Input Fields').first().json.question_count + 1\n  }\n}];"
      },
