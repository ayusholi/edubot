    {
      "parameters": {
        "promptType": "define",
        "text": "=Evaluate this quiz answer:\n\nQuestion: {{ JSON.parse($('Set Input Fields').first().json.quiz_session).current_question }}\n\nOptions:\nA. {{ JSON.parse($('Set Input Fields').first().json.quiz_session).options ? JSON.parse(JSON.parse($('Set Input Fields').first().json.quiz_session).options).A : '' }}\nB. {{ JSON.parse($('Set Input Fields').first().json.quiz_session).options ? JSON.parse(JSON.parse($('Set Input Fields').first().json.quiz_session).options).B : '' }}\nC. {{ JSON.parse($('Set Input Fields').first().json.quiz_session).options ? JSON.parse(JSON.parse($('Set Input Fields').first().json.quiz_session).options).C : '' }}\nD. {{ JSON.parse($('Set Input Fields').first().json.quiz_session).options ? JSON.parse(JSON.parse($('Set Input Fields').first().json.quiz_session).options).D : '' }}\n\nCorrect answer: {{ $('Set Input Fields').first().json.correct_answer }}\nStudent answered: {{ $('Set Input Fields').first().json.user_message.toUpperCase() }}\nIs correct: {{ $('Set Input Fields').first().json.is_correct }}\nNew score: {{ $('Set Input Fields').first().json.new_score }}/{{ $('Set Input Fields').first().json.question_count }}\n\nGenerate the evaluation response.",
        "options": {
          "systemMessage": "You are the Quiz Evaluator for Edubot, an MSc AI tutor.\n\nGenerate a clear, encouraging evaluation response.\n\nIf CORRECT:\n✅ Correct! [One sentence explaining WHY this is right.]\n\nScore: X/Y\n\nWould you like another question? Reply *Yes* to continue or *No* to end the quiz.\n\nIf INCORRECT:\n❌ Not quite! The correct answer was *[letter]. [option text]*.\n[One sentence explaining why it's correct.]\n\nScore: X/Y\n\nWould you like another question? Reply *Yes* to continue or *No* to end the quiz.\n\nRules:\n- Keep explanations brief but educational.\n- Be encouraging regardless of the result.\n- Always show the updated score.\n- Always end with the yes/no prompt."
        }
      },
