    {
      "parameters": {
        "jsCode": "let html = $('Store Summary Text').first().json.summary_text || '';\n\n// Remove markdown code fences if the agent adds them\nhtml = html\n  .replace(/^```html\\s*/i, '')\n  .replace(/^```\\s*/i, '')\n  .replace(/```$/i, '')\n  .trim();\n\n// If the agent returned a full HTML document, keep only the body content\nconst bodyMatch = html.match(/<body[^>]*>([\\s\\S]*?)<\\/body>/i);\nif (bodyMatch) {\n  html = bodyMatch[1].trim();\n}\n\nreturn [\n  {\n    json: {\n      clean_summary_html: html\n    }\n  }\n];"
      },
