    {
      "parameters": {
        "html": "=<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>{{ $('Set Input Fields').first().json.course_name }} - Week {{ $('Set Input Fields').first().json.week_number }} Summary</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      color: #1a1a2e;\n      line-height: 1.6;\n      background: #ffffff;\n      padding: 24px;\n    }\n\n    .header {\n      background: #f3f6fb;\n      color: #1a1a2e;\n      padding: 24px;\n      border: 1px solid #d9e2ef;\n      margin-bottom: 32px;\n    }\n\n    .badge {\n      display: inline-block;\n      color: #0f3460;\n      font-weight: 600;\n      font-size: 12px;\n      margin-bottom: 8px;\n    }\n\n    .header h1 {\n      margin: 8px 0 8px 0;\n      font-size: 26px;\n      font-weight: 700;\n      color: #1a1a2e;\n    }\n\n    .header .subtitle {\n      margin: 0;\n      font-size: 14px;\n      color: #3b4a60;\n    }\n\n    h2 {\n      color: #0f3460;\n      border-left: 4px solid #e94560;\n      padding-left: 12px;\n      margin-top: 30px;\n      font-size: 20px;\n    }\n\n    h3 {\n      color: #16213e;\n      font-size: 16px;\n      margin-top: 20px;\n    }\n\n    p {\n      margin: 10px 0;\n      font-size: 14px;\n    }\n\n    ul {\n      padding-left: 24px;\n      margin-top: 8px;\n      margin-bottom: 16px;\n    }\n\n    li {\n      margin-bottom: 6px;\n      font-size: 14px;\n    }\n\n    strong {\n      color: #0f3460;\n      font-weight: 700;\n    }\n\n    blockquote {\n      border-left: 3px solid #e94560;\n      margin: 16px 0;\n      padding: 8px 16px;\n      background: #f8f9fa;\n    }\n\n    code {\n      background: #f0f0f0;\n      padding: 2px 6px;\n      font-family: \"Courier New\", monospace;\n      font-size: 13px;\n    }\n\n    .footer {\n      margin-top: 48px;\n      padding-top: 20px;\n      border-top: 1px solid #d9e2ef;\n      text-align: center;\n      font-size: 12px;\n      color: #666666;\n    }\n\n    .generated-date {\n      color: #777777;\n      font-size: 11px;\n      margin-top: 4px;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"header\">\n    <div class=\"badge\">📚 Edubot Study Summary</div>\n    <h1>{{ $('Set Input Fields').first().json.course_name }}</h1>\n    <p class=\"subtitle\">\n      Week {{ $('Set Input Fields').first().json.week_number }}{{ $('Set Input Fields').first().json.topic ? ' · ' + $('Set Input Fields').first().json.topic : '' }} · MSc Artificial Intelligence · Northumbria University\n    </p>\n  </div>\n\n  {{ $('Clean Summary HTML').first().json.clean_summary_html }}\n\n  <div class=\"footer\">\n    <p>Generated by Edubot AI Tutor</p>\n    <p class=\"generated-date\">{{ $now.toFormat('dd MMMM yyyy, HH:mm') }}</p>\n  </div>\n</body>\n</html>"
