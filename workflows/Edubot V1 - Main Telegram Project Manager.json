      "parameters": {
        "jsCode": "const messages = $input.all()\n  .filter(item => item.json && item.json.message_text)\n  .map(item => item.json);\n\n// Optional: sort oldest to newest if created_at exists\nmessages.sort((a, b) => {\n  const dateA = new Date(a.created_at || 0).getTime();\n  const dateB = new Date(b.created_at || 0).getTime();\n  return dateA - dateB;\n});\n\nconst recentConversation = messages.length > 0\n  ? messages\n      .map(m => {\n        const speaker = m.role === 'user' ? 'Student' : 'Edubot';\n        return `${speaker}: ${m.message_text}`;\n      })\n      .join('\\n')\n  : 'No previous messages.';\n\nreturn [\n  {\n    json: {\n      recent_conversation: recentConversation\n    }\n  }\n];"
      },
