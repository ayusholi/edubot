    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst rawMessage = input.raw_message?.trim().toUpperCase() || '';\n\nlet quizState;\ntry {\n  quizState = typeof input.quiz_state === 'string' ? JSON.parse(input.quiz_state) : input.quiz_state;\n} catch(e) {\n  quizState = { questions: [], current_question: 0, score: 0, total: 0, answers_given: [] };\n}\n\nif (!quizState || !quizState.questions || quizState.questions.length === 0) {\n  return [{ json: { error: 'No active quiz', chat_id: input.chat_id, telegram_user_id: input.telegram_user_id } }];\n}\n\nconst currentQ = quizState.questions[quizState.current_question];\nconst userAnswer = rawMessage.charAt(0);\nconst isCorrect = userAnswer === currentQ.correct;\n\nif (isCorrect) quizState.score++;\nquizState.answers_given.push({ answer: userAnswer, correct: isCorrect });\nquizState.current_question++;\n\nconst isComplete = quizState.current_question >= quizState.total;\n\nlet feedbackText = isCorrect\n  ? `✅ *Correct!* Well done!\\n\\n_${currentQ.explanation}_`\n  : `❌ *Incorrect.* The correct answer was *${currentQ.correct}*.\\n\\n_${currentQ.explanation}_`;\n\nreturn [{\n  json: {\n    quiz_state: quizState,\n    feedback: feedbackText,\n    is_correct: isCorrect,\n    is_complete: isComplete,\n    chat_id: input.chat_id,\n    telegram_user_id: input.telegram_user_id,\n    current_question_index: quizState.current_question,\n    score: quizState.score,\n    total: quizState.total,\n    topic: quizState.topic\n  }\n}];"
      },
