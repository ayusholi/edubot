    {
      "parameters": {
        "jsCode": "const data = $('Parse Answer').item.json;\nconst { score, total, topic, feedback } = data;\nconst percentage = Math.round((score / total) * 100);\n\nlet grade = '';\nlet emoji = '';\nif (percentage === 100) { grade = 'Perfect Score! Outstanding! 🏆'; emoji = '🌟'; }\nelse if (percentage >= 80) { grade = 'Excellent work! 🎉'; emoji = '✨'; }\nelse if (percentage >= 60) { grade = 'Good effort! Keep studying! 💪'; emoji = '👍'; }\nelse { grade = \"Keep practicing! You'll get there! 📚\"; emoji = '🔄'; }\n\nconst reviewItems = data.quiz_state.answers_given\n  .map((a, i) => !a.correct ? `• Q${i+1}: ${data.quiz_state.questions[i].question.slice(0,60)}...\\n  ✓ Correct: ${data.quiz_state.questions[i].correct}` : null)\n  .filter(Boolean);\n\nconst reviewText = reviewItems.length > 0\n  ? `\\n\\n*Topics to review:*\\n${reviewItems.join('\\n\\n')}`\n  : '\\n\\n✅ You answered everything correctly!';\n\nconst finalText = `${feedback}\\n\\n---\\n\\n${emoji} *Quiz Complete!*\\n\\n📊 *Your Score: ${score}/${total} (${percentage}%)*\\n\\n${grade}${reviewText}\\n\\n_Type /quiz ${topic} to try again, or ask me about any topic!_`;\n\nreturn [{ json: { message_text: finalText, chat_id: data.chat_id } }];"
      },
