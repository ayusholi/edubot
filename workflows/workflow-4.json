          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"google/gemma-4-26b-a4b-it:free\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an educational quiz generator for a Masters in AI Technology programme at Northumbria University. You ONLY generate questions related to these modules: Programming for AI, IoT for AI, Machine Learning on Cloud, Leadership in Digital Age, Professional Practice, Contemporary Computing and Digital Technology, Information Governance and Cyber Security. Always return valid JSON only, no other text.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Generate a 5-question multiple choice quiz about: {{ $json.quiz_topic }}\\n\\nUse this course material if available:\\n{{ $json.course_content ?? 'Use general knowledge about the topic.' }}\\n\\nReturn ONLY this exact JSON structure (no markdown, no explanation):\\n{\\\"questions\\\":[{\\\"question\\\":\\\"...\\\",\\\"options\\\":[\\\"A) ...\\\",\\\"B) ...\\\",\\\"C) ...\\\",\\\"D) ...\\\"],\\\"correct\\\":\\\"A\\\",\\\"explanation\\\":\\\"...\\\"}]}\"\n    }\n  ],\n  \"temperature\": 0.5,\n  \"max_tokens\": 1500\n}",
        "options": {}
      },
      "id": "n3",
      "name": "Generate Quiz Questions",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1008,
        160
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "paFcUHaGmuSqV28f",
          "name": "Gemma"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst content = response.choices[0].message.content;\n\nconst cleaned = content\n  .replace(/```json/g, '')\n  .replace(/```/g, '')\n  .trim();\n\nlet quiz;\ntry {\n  quiz = JSON.parse(cleaned);\n} catch(e) {\n  const match = cleaned.match(/\\{[\\s\\S]*\\}/);\n  quiz = match ? JSON.parse(match[0]) : { questions: [] };\n}\n\nif (!quiz.questions || quiz.questions.length === 0) {\n  return [{\n    json: {\n      error: true,\n      chat_id: '',\n      message: \"❌ Sorry! I can only quiz you on your course modules.\"\n    }\n  }];\n}\n\nconst triggerData = $('Route Quiz Action').item.json;\n\nconst quizState = {\n  questions: quiz.questions,\n  current_question: 0,\n  score: 0,\n  total: quiz.questions.length,\n  topic: triggerData.quiz_topic,\n  answers_given: []\n};\n\nreturn [{\n  json: {\n    quiz_state: quizState,\n    first_question: quiz.questions[0],\n    topic: triggerData.quiz_topic,\n    telegram_user_id: triggerData.telegram_user_id,\n    chat_id: triggerData.chat_id\n  }\n}];"
      },
