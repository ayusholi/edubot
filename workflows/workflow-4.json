    {
      "parameters": {
        "jsCode": "const quizState = $('Parse Quiz JSON').item.json.quiz_state;\nconst q = quizState.questions[0];\n\nconst text = `🎮 *Quiz: ${quizState.topic}*\\n\\n*Question 1 of ${quizState.total}:*\\n\\n${q.question}\\n\\n${q.options.join('\\n')}`;\n\nreturn [{\n  json: {\n    question_text: text,\n    chat_id: $('Parse Quiz JSON').item.json.chat_id\n  }\n}];"
      },
      "id": "n6",
      "name": "Format First Question",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
